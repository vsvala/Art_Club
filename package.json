{
  "name": "artclub",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:3001",
  "scripts": {
    "server": "json-server -p3001 db.json",
    "dev": "react-scripts start",
    "build": "react-scripts build",
    "test": "CI=true react-scripts test --env=jsdom",
    "test-coverage": "CI=true react-scripts test --env=jsdom --coverage",
    "test-e2e": "playwright test",
    "test-e2e:report": "playwright show-report",
    "codecov": "./node_modules/.bin/codecov",
    "eject": "react-scripts eject",
    "lint": "eslint .",
    "deploy": "npm run build && cp -r build ../Art_Club_back/ && cd ../Art_Club_back && git add build && git commit -m 'update frontend build' && git push origin master"
  },
  "dependencies": {
    "@sentry/react": "^10.63.0",
    "@tanstack/react-query": "^4.44.0",
    "axios": "^1.9.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "form-data": "^2.4.0",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-datepicker": "^7.0.0",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.28.2",
    "react-scripts": "5.0.1",
    "read-more-react": "^1.0.9",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^26.1.0",
    "babel-eslint": "^10.0.1",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "deep-freeze": "0.0.1",
    "eslint-config-prettier": "^10.1.8",
    "json-server": "^1.0.0-beta.15",
    "msw": "^1.3.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "nth-check": ">=2.0.1",
    "postcss": ">=8.4.31",
    "serialize-javascript": ">=6.0.2",
    "@tootallnate/once": ">=2.0.1",
    "underscore": ">=1.13.8",
    "uuid": ">=11.1.1"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/test/**",
      "!src/index.js",
      "!src/setupTests.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 60,
        "functions": 60,
        "branches": 55,
        "statements": 60
      }
    }
  },
  "babel": {
    "env": {
      "production": {
        "plugins": [
          "transform-remove-console"
        ]
      }
    }
  }
}
